// This source code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// Disclaimer:
// Educational purposes only. Not financial advice. Past strategy performance does not guarantee future results.
// Based on Kristjan Kullamägi (Qullamaggie) Breakout Setup 1 — flag/continuation breakout.
// Reference: https://qullamaggie.com/my-3-timeless-setups-that-have-made-me-tens-of-millions/
//
// SETUP RULES:
//   1. Prior big move   : instrument ran prior_mv_pct%+ in the prior_mv_len bars before the consolidation
//   2. Consolidation    : ATR has compressed to compress_ratio × its prior value; higher lows in recent vs earlier half
//   3. Bull backdrop    : Fast EMA above Slow EMA
//   4. Entry            : Daily close breaks above the consolidation high (pivot)
//   5. Stop             : LOD of the entry bar, capped at atr_sl_mult × ATR
//   6. Phase 2 (bars N) : Close partial_pct% of position after partial_bars bars; move stop to break-even
//   7. Phase 3 (trail)  : Trail remaining stop on the trailing MA; exit on close below it

//@version=6
strategy('Qullamaggie — Breakout Setup 1',
         overlay           = true,
         default_qty_type  = strategy.percent_of_equity,
         default_qty_value = 10,
         pyramiding        = 0,
         commission_type   = strategy.commission.percent,
         commission_value  = 0.05,
         slippage          = 2,
         max_bars_back     = 500)

// ═══════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════

// ── Consolidation / Breakout ─────────────────────────────
consol_len     = input.int(20,    'Consolidation Lookback (bars)',  minval=5,   maxval=60,  group='Setup 1 — Breakout')
prior_mv_len   = input.int(60,    'Prior Move Lookback (bars)',     minval=10,  maxval=200, group='Setup 1 — Breakout')
prior_mv_pct   = input.float(20.0,'Min Prior Move (%)',             step=1.0,   minval=5.0, group='Setup 1 — Breakout')
compress_ratio = input.float(0.75,'ATR Compression Ratio',          step=0.05,  minval=0.1, maxval=1.0, group='Setup 1 — Breakout')

// ── Risk ────────────────────────────────────────────────
atr_len        = input.int(14,    'ATR Length',                     minval=1,               group='Risk')
atr_sl_mult    = input.float(1.0, 'Stop: ATR Cap (× ATR)',          step=0.1,  minval=0.1,  group='Risk')
partial_pct    = input.float(50.0,'Partial Exit %',                 step=5.0,  minval=5.0, maxval=95.0, group='Risk')
partial_bars   = input.int(5,     'Partial Exit After N Bars',      minval=1,               group='Risk')

// ── Trailing MA ──────────────────────────────────────────
trail_len      = input.int(10,    'Trailing MA Length',             minval=3,               group='Trail')
use_ema_trail  = input.bool(true,  'Trail on EMA (else SMA)',                               group='Trail')

// ── Trend Filter ─────────────────────────────────────────
ema_fast_len   = input.int(20,    'Fast EMA',                       minval=1,               group='Trend Filter')
ema_slow_len   = input.int(50,    'Slow EMA',                       minval=1,               group='Trend Filter')

// ── Display ──────────────────────────────────────────────
show_consol_h  = input.bool(true,  'Show Consolidation High',                               group='Display')
show_trail_ma  = input.bool(true,  'Show Trailing MA',                                      group='Display')
show_stop_line = input.bool(true,  'Show Active Stop Line',                                 group='Display')
show_emas      = input.bool(true,  'Show Trend EMAs',                                       group='Display')
show_table     = input.bool(true,  'Show Info Table',                                       group='Display')

// ═══════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════

ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
trail_ma = use_ema_trail ? ta.ema(close, trail_len) : ta.sma(close, trail_len)
atr_val  = ta.atr(atr_len)

// ── 1. Bull backdrop ─────────────────────────────────────
bull_backdrop = ema_fast > ema_slow

// ── 2. Prior big move ────────────────────────────────────
// Lowest close in the prior_mv_len bars that precede the consolidation window
prior_base   = ta.lowest(close, prior_mv_len)[consol_len + 1]
had_big_move = prior_base > 0 and (close - prior_base) / prior_base * 100 >= prior_mv_pct

// ── 3. ATR compression ───────────────────────────────────
// Current 10-bar ATR is compress_ratio × the ATR at the start of the consolidation window
atr_now      = ta.atr(10)
atr_then     = ta.atr(atr_len)[consol_len]
is_compressed = atr_then > 0 and atr_now / atr_then <= compress_ratio

// ── 4. Higher lows ───────────────────────────────────────
// Recent half of consolidation must have higher lows than the earlier half
int half    = math.max(math.round(consol_len / 2), 2)
recent_low  = ta.lowest(low, half)[1]
earlier_low = ta.lowest(low, half)[half + 1]
higher_lows = recent_low >= earlier_low

// ── Consolidation pivot high (the level to break) ────────
consol_high = ta.highest(high, consol_len)[1]

// ── All pre-breakout criteria ─────────────────────────────
setup_forming = bull_backdrop and had_big_move and is_compressed and higher_lows

// ── Entry: daily close breaks above consolidation high ───
breakout = setup_forming and close > consol_high and strategy.position_size == 0

// ═══════════════════════════════════════════════════════════
// STATE TRACKING
// ═══════════════════════════════════════════════════════════

var float entry_px      = na
var float stop_px       = na
var int   entry_bar_idx = na
var bool  partial_done  = false

// Initialise state on the first bar the position is open
// Entry fills at the open of this bar (default strategy behaviour)
if strategy.position_size > 0 and strategy.position_size[1] == 0
    entry_px      := strategy.opentrades.entry_price(0)
    sl_raw         = math.min(entry_px - low, atr_val * atr_sl_mult)
    stop_px       := entry_px - sl_raw
    entry_bar_idx := bar_index
    partial_done  := false

// Clear state when flat
if strategy.position_size == 0 and strategy.position_size[1] != 0
    entry_px      := na
    stop_px       := na
    entry_bar_idx := na
    partial_done  := false

// ═══════════════════════════════════════════════════════════
// ENTRY
// ═══════════════════════════════════════════════════════════

if breakout
    strategy.entry('Long', strategy.long, comment='BO')

// ═══════════════════════════════════════════════════════════
// EXIT MANAGEMENT (three phases)
// ═══════════════════════════════════════════════════════════
//
//  Phase 1 — Initial stop at LOD capped at 1×ATR
//  Phase 2 — After partial_bars: close partial_pct%, raise stop to break-even
//  Phase 3 — Trail remaining position on the MA; stop only moves up
//

if strategy.position_size > 0 and not na(entry_bar_idx)
    bars_in = bar_index - entry_bar_idx

    // Phase 2: partial exit, then breakeven stop
    if not partial_done and bars_in >= partial_bars
        strategy.close('Long', qty_percent=partial_pct,
             comment='Partial ' + str.tostring(math.round(partial_pct)) + '%')
        partial_done := true
        stop_px      := math.max(stop_px, entry_px)    // floor at break-even

    // Phase 3: trail on MA — stop only ratchets up
    if partial_done
        stop_px := math.max(stop_px, trail_ma)

    // Apply dynamic stop every bar (same id updates the order)
    strategy.exit('DynStop', 'Long', stop=stop_px)

// ═══════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════

// Trend EMAs
plot(show_emas ? ema_fast : na, 'EMA Fast',
     color=color.new(color.orange, 0), linewidth=1)
plot(show_emas ? ema_slow : na, 'EMA Slow',
     color=color.new(color.blue,   0), linewidth=1)

// Trailing MA — visible only while in a trade
plot(show_trail_ma and strategy.position_size > 0 ? trail_ma : na, 'Trail MA',
     color=color.new(color.yellow, 0), linewidth=2, style=plot.style_linebr)

// Consolidation pivot high — visible while setup is forming, not yet triggered
plot(show_consol_h and setup_forming and strategy.position_size == 0 ? consol_high : na, 'Consol High',
     color=color.new(color.white, 30), linewidth=1, style=plot.style_stepline)

// Active stop line — visible while in a trade
plot(show_stop_line and strategy.position_size > 0 ? stop_px : na, 'Stop',
     color=color.new(color.red, 20), linewidth=1, style=plot.style_linebr)

// Breakout entry arrow
plotshape(breakout, 'Breakout Entry',
     style=shape.triangleup, location=location.belowbar,
     color=color.lime, size=size.normal, text='BO')

// Yellow bar tint while setup is forming (pre-breakout)
barcolor(setup_forming and strategy.position_size == 0 and not breakout
     ? color.new(color.yellow, 70) : na)

// ═══════════════════════════════════════════════════════════
// INFO TABLE  (bottom-right)
// ═══════════════════════════════════════════════════════════

var table tbl = table.new(position.bottom_right, 2, 8,
     bgcolor     = color.new(color.black, 70),
     frame_width = 1,
     frame_color = color.new(color.white, 80))

if barstate.islast and show_table
    bool   in_trade = strategy.position_size > 0
    int    bars_in  = in_trade and not na(entry_bar_idx) ? bar_index - entry_bar_idx : 0
    string phase    = not in_trade ? '—'
         : partial_done   ? 'Phase 3: Trailing'
         : bars_in >= partial_bars ? 'Phase 2: Partial →'
         : 'Phase 1: Initial (' + str.tostring(bars_in) + '/' + str.tostring(partial_bars) + ')'

    table.cell(tbl, 0, 0, 'CONDITION',       text_color=color.white, text_size=size.large, bgcolor=color.new(color.navy, 40))
    table.cell(tbl, 1, 0, 'STATUS',          text_color=color.white, text_size=size.large, bgcolor=color.new(color.navy, 40))

    table.cell(tbl, 0, 1, 'Bull Backdrop',   text_color=color.white, text_size=size.large)
    table.cell(tbl, 1, 1, bull_backdrop   ? '▲ YES' : '▼ NO',
               text_color=bull_backdrop   ? color.lime : color.red,    text_size=size.large)

    table.cell(tbl, 0, 2, 'Prior Big Move',  text_color=color.white, text_size=size.large)
    table.cell(tbl, 1, 2, had_big_move    ? '✓ YES' : '✗ NO',
               text_color=had_big_move    ? color.lime : color.red,    text_size=size.large)

    table.cell(tbl, 0, 3, 'ATR Compressed', text_color=color.white, text_size=size.large)
    table.cell(tbl, 1, 3, is_compressed   ? '✓ YES' : '✗ NO',
               text_color=is_compressed   ? color.lime : color.red,    text_size=size.large)

    table.cell(tbl, 0, 4, 'Higher Lows',    text_color=color.white, text_size=size.large)
    table.cell(tbl, 1, 4, higher_lows      ? '✓ YES' : '✗ NO',
               text_color=higher_lows      ? color.lime : color.red,   text_size=size.large)

    table.cell(tbl, 0, 5, 'Setup Ready',    text_color=color.white, text_size=size.large)
    table.cell(tbl, 1, 5, setup_forming    ? '★ READY' : '— NO',
               text_color=setup_forming    ? color.yellow : color.gray, text_size=size.large)

    table.cell(tbl, 0, 6, 'Trade Phase',    text_color=color.white, text_size=size.large)
    table.cell(tbl, 1, 6, phase,
               text_color=partial_done ? color.yellow : in_trade ? color.lime : color.gray, text_size=size.large)

    table.cell(tbl, 0, 7, 'Active Stop',    text_color=color.white, text_size=size.large)
    table.cell(tbl, 1, 7, in_trade and not na(stop_px) ? str.tostring(stop_px, '#.##') : '—',
               text_color=in_trade ? color.red : color.gray,           text_size=size.large)
