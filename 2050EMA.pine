//@version=6

strategy(
     "EMA Cross Strategy",
     overlay=true,
     calc_on_every_tick=true,
     currency=currency.AUD
     )

// INPUT:
// if not timeframe.isweekly
//     runtime.error("Please use this script on a weekly chart.")

// Options to enter fast and slow Exponential Moving Average (EMA) values
emaFast = input.int(title="Fast EMA", defval=20, minval=1, maxval=9999)
emaSlow = input.int(title="Slow EMA", defval=50, minval=1, maxval=9999)
tradeDirection = input.string(title="Trade Direction", options=["Long", "Short", "Both"], defval="Long")
startDate = input.time(title="Start Date", defval=timestamp("01 Jan 1970 00:00"))
endDate = input.time(title="End Date", defval=timestamp("31 Dec 2170 23:59"))

// CALCULATIONS:

// Use the built-in function to calculate two EMA lines
fastEMA = ta.ema(close, emaFast)
slowEMA = ta.ema(close, emaSlow)

// PLOT:

// Draw the EMA lines on the chart
plot(fastEMA, color=color.green, linewidth=2, title="Fast EMA")
plot(slowEMA, color=color.red, linewidth=2, title="Slow EMA")

// CONDITIONS:

inDateRange = (time >= startDate) and (time < endDate)
longOK  = (tradeDirection == "Long") or (tradeDirection == "Both")
shortOK = (tradeDirection == "Short") or (tradeDirection == "Both")
longCondition = ta.crossover(fastEMA, slowEMA)
shortCondition = ta.crossunder(fastEMA, slowEMA)

// ORDERS:

// Submit entry (or reverse) orders
if (longCondition and inDateRange and longOK)
    strategy.entry("long", strategy.long)
if (shortCondition and inDateRange and shortOK)
    strategy.entry("short", strategy.short)

// Submit exit orders in the cases where we trade only long or only short
if (strategy.position_size > 0 and shortCondition)
    strategy.close("long")
if (strategy.position_size < 0 and longCondition)
    strategy.close("short")

// --- Buy/Sell Count to 9 Indicator (integrated) ---

// Inputs
showFrom     = input.int(1, "Show numbers from", minval=1, maxval=9)
showTo       = input.int(9, "Show numbers to", minval=1, maxval=9)
sizeInput    = input.string("normal", "Numbers size", options=["tiny", "small", "normal", "large", "huge"])
showLines    = input.bool(true, "Show support/resistance lines")

// Color settings
buyNumberColor  = input.color(color.red,  "Buy number color")
sellNumberColor = input.color(color.teal, "Sell number color")
buyLineColor    = input.color(color.red,  "Buy line color")
sellLineColor   = input.color(color.teal, "Sell line color")

// Helper function: Convert size string to label.size
f_getSize(strSize) =>
    switch strSize
        "tiny"   => size.tiny
        "small"  => size.small
        "normal" => size.normal
        "large"  => size.large
        "huge"   => size.huge
        => size.small

labelSize = f_getSize(sizeInput)

// Range check
isInRange(val) =>
    val >= showFrom and val <= showTo

maxCount = 9
barsBack = 4

// Counters
var int buyCount = 0
var int sellCount = 0
var int lastBuyCount = 0
var int lastSellCount = 0

buyCond  = close < close[barsBack]
sellCond = close > close[barsBack]

// Line references
var line buyLine = na
var line sellLine = na

if barstate.isconfirmed
    // Buy counter
    if buyCond
        if buyCount < maxCount
            buyCount += 1
    else
        buyCount := 0

    // Sell counter
    if sellCond
        if sellCount < maxCount
            sellCount += 1
    else
        sellCount := 0

    // Buy label (number only, no box)
    if buyCount > 0 and isInRange(buyCount) and buyCount != lastBuyCount
        label.new(bar_index, low * 0.999, text=str.tostring(buyCount),
             style=label.style_label_center,
             textcolor=buyNumberColor,
             color=color.new(color.white, 100),
             yloc=yloc.belowbar,
             size=labelSize)
        lastBuyCount := buyCount

    // Sell label (number only, no box)
    if sellCount > 0 and isInRange(sellCount) and sellCount != lastSellCount
        label.new(bar_index, high * 1.001, text=str.tostring(sellCount),
             style=label.style_label_center,
             textcolor=sellNumberColor,
             color=color.new(color.white, 100),
             yloc=yloc.abovebar,
             size=labelSize)
        lastSellCount := sellCount

    // Support line at Buy-9
    if showLines
        if buyCount == 9 and bar_index >= 2
            if not na(buyLine)
                line.delete(buyLine)
            buyLine := line.new(bar_index - 2, close[2], bar_index, close[2], extend=extend.none, color=buyLineColor, width=2)

        if not na(buyLine) and buyCount != 9
            line.set_x2(buyLine, bar_index)
            line.set_y2(buyLine, line.get_y1(buyLine))

    // Resistance line at Sell-9
    if showLines
        if sellCount == 9 and bar_index >= 2
            if not na(sellLine)
                line.delete(sellLine)
            sellLine := line.new(bar_index - 2, close[2], bar_index, close[2], extend=extend.none, color=sellLineColor, width=2)

        if not na(sellLine) and sellCount != 9
            line.set_x2(sellLine, bar_index)
            line.set_y2(sellLine, line.get_y1(sellLine))

    // Reset last values
    if buyCount == 0
        lastBuyCount := 0
    if sellCount == 0
        lastSellCount := 0

// === Extra EMA Indicator with Smoothing and Bollinger Bands ===

// Main EMA input
emaInd_len = input.int(9, minval=1, title="Extra EMA Length")
emaInd_src = input(close, title="Extra EMA Source")
emaInd_offset = input.int(title="Extra EMA Offset", defval=0, minval=-500, maxval=500, display = display.data_window)
emaInd_out = ta.ema(emaInd_src, emaInd_len)
plot(emaInd_out, title="Extra EMA (Blue)", color=color.blue, offset=emaInd_offset)

// Smoothing MA inputs
GRP = "Smoothing"
TT_BB = "Only applies when 'SMA + Bollinger Bands' is selected. Determines the distance between the SMA and the bands."
maTypeInput = input.string("None", "Smoothing Type", options = ["None", "SMA", "SMA + Bollinger Bands", "EMA", "SMMA (RMA)", "WMA", "VWMA"], group = GRP, display = display.data_window)
isBB = maTypeInput == "SMA + Bollinger Bands"
maLengthInput = input.int(14, "Smoothing Length", group = GRP, display = display.data_window, active = maTypeInput != "None")
bbMultInput = input.float(2.0, "BB StdDev", minval = 0.001, maxval = 50, step = 0.5, tooltip = TT_BB, group = GRP, display = display.data_window, active = isBB)
enableMA = maTypeInput != "None"

// Smoothing MA Calculation
ma(source, length, MAtype) =>
    switch MAtype
        "SMA"                   => ta.sma(source, length)
        "SMA + Bollinger Bands" => ta.sma(source, length)
        "EMA"                   => ta.ema(source, length)
        "SMMA (RMA)"            => ta.rma(source, length)
        "WMA"                   => ta.wma(source, length)
        "VWMA"                  => ta.vwma(source, length)

// Smoothing MA plots
smoothingMA = enableMA ? ma(emaInd_out, maLengthInput, maTypeInput) : na
smoothingStDev = isBB ? ta.stdev(emaInd_out, maLengthInput) * bbMultInput : na
plot(smoothingMA, "EMA-based MA", color=color.yellow, display = enableMA ? display.all : display.none, editable = enableMA)
bbUpperBand = plot(smoothingMA + smoothingStDev, title = "Upper Bollinger Band", color=color.green, display = isBB ? display.all : display.none, editable = isBB)
bbLowerBand = plot(smoothingMA - smoothingStDev, title = "Lower Bollinger Band", color=color.green, display = isBB ? display.all : display.none, editable = isBB)
fill(bbUpperBand, bbLowerBand, color= isBB ? color.new(color.green, 90) : na, title="Bollinger Bands Background Fill", display = isBB ? display.all : display.none, editable = isBB)
